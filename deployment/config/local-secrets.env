# Local Secrets for tiketi
# This file contains local development secrets

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_DATABASE=tiketi_dev
DB_USERNAME=tiketi_user
DB_PASSWORD=tiketi_pass

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# GitHub Container Registry (for CI/CD)
GHCR_USERNAME=
GHCR_PAT=

# App Configuration
APP_URL=http://tiketi.localhost
ASSET_URL=http://tiketi.localhost
CENTRAL_DOMAIN=tiketi.localhost
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

# Reverb (WebSocket) Configuration
REVERB_APP_ID=100001
REVERB_APP_KEY=tiketi_local_key
REVERB_APP_SECRET=tiketi_local_secret
REVERB_HOST="0.0.0.0"
REVERB_PORT=6001
REVERB_SCHEME=http

# Vite Reverb Configuration (Exposed to Frontend)
VITE_REVERB_APP_KEY=tiketi_local_key
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT=6001
VITE_REVERB_SCHEME=http
