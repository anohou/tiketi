# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  template.env — Application key manifest                                    ║
# ║                                                                             ║
# ║  SAFE TO COMMIT. No secrets here.                                          ║
# ║  Keys with values → committed non-secret defaults.                         ║
# ║  Keys with no value (KEY=) → filled from server secret files at deploy.   ║
# ║  Edit this to add/remove keys. Only keys listed here appear in .env.       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Deployment (config.yml-derived, injected by generate-env.sh) ──────────────
APP_SLUG=
APP_IMAGE=
DEPLOY_IMAGE_REFERENCE=
COMPOSE_PROJECT_NAME=app
TRAEFIK_SWARM_NETWORK=
NGINX_IMAGE=

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Laravel App"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=
ASSET_URL=
APP_DOMAIN=
TENANT_WILDCARD_DOMAIN=
FRONTEND_URL=https://stg.tiketi.ci
CORS_ALLOWED_ORIGINS=https://stg.tiketi.ci,https://*.stg.tiketi.ci
APP_VERSION=
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_PORT=5432
DB_HOST=
DB_DATABASE=
DB_SCHEMA=app
DB_USERNAME=
DB_PASSWORD=
DB_PROVISIONER_USERNAME=
DB_PROVISIONER_PASSWORD=
TENANT_DB_PREFIX=app_tenant_tiketi_

# Migration credentials — isolated from runtime, used only during deploy
# Never loaded into the runtime PHP-FPM containers
DB_MIGRATOR_USERNAME=
DB_MIGRATOR_PASSWORD=

# ── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=
CACHE_STORE=file
CACHE_PREFIX=
QUEUE_CONNECTION=database

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Filament ──────────────────────────────────────────────────────────────────
FILAMENT_FILESYSTEM_DISK=local

# ── Frontend / Centralized URLs ──────────────────────────────────────────────
CENTRALIZED_API_URL=
ADMIN_APP_URL=
MEMBER_APP_URL=
DASHBOARD_URL=
WEB_URL=

# Comma-separated list of allowed Admin emails or domains.
# Example: "admin@example.com,*@example.com"
# If populated, the create-admin.sh utility strictly enforces this whitelist.
ADMIN_EMAIL_WHITELIST=

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=single
LOG_LEVEL=info

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# ── OAuth / Realtime / Frontend Build ────────────────────────────────────────
GOOGLE_REDIRECT_URI=
REVERB_ENABLED=false
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=
REVERB_SCHEME=
REVERB_SERVER_HOST=
REVERB_SERVER_PORT=
REVERB_SERVER_SCHEME=
VITE_APP_NAME=
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=
VITE_APP_ENV=

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Ekkou Agent ───────────────────────────────────────────────────────────────
AGENT_KEY=

# ── Traefik ───────────────────────────────────────────────────────────────────
TRAEFIK_CERT_RESOLVER=letsencrypt
